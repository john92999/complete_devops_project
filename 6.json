{
  "Version": "2012-10-17",
  "Id": "FourthPolicyForLearning",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:Get*",
        "s3:List*",
        "s3-object-lambda:Get*",
        "s3-object-lambda:List*"
      ],
      "Resource": ["arn:aws:s3:::sample-bucket", "arn:aws:s3:::sample-bucket/*"]
    }
  ]
}
